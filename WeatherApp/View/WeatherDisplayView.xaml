<UserControl x:Class="WeatherApp.View.WeatherDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WeatherApp.View"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="350">

    <!-- MAIN CARD -->
    <Border Width="300"
            Margin="10 0 0 0 "
            Background="White"
            CornerRadius="30"
            Padding="25">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="220" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- SEARCH BAR -->
            <StackPanel Orientation="Horizontal">
                <Border Grid.Row="0"
                        Height="45"
                        Width="200"
                        Background="#F3F3F3"
                        CornerRadius="15">

                    <Grid Margin="15,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- SEARCH ICON -->
                        <TextBlock Text="🔍"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Foreground="#777" />

                        <!-- SEARCH BOX -->
                        <TextBox Grid.Column="1"
                                 Margin="10,0,0,0"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="15"
                                 VerticalContentAlignment="Center"
                                 Foreground="#444"
                                 Text="{Binding City}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>

                    </Grid>
                </Border>
                <Button Content="🔍"
                        Width="30"
                        Margin="5"
                        Command="{Binding SearchCommand}" />
            </StackPanel>

            <!-- WEATHER ICON -->
            <Grid Grid.Row="1">

                <TextBlock Text="{Binding Icon}" 
                           FontSize="100"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

            </Grid>

            <!-- TEMPERATURE -->
            <TextBlock Grid.Row="2"
                       Text="{Binding Temperature,StringFormat = {}{0}°}"
                       FontSize="72"
                       FontWeight="Light"
                       Foreground="#111111"
                       Margin="0,10,0,0" />

            <!-- DATE -->
            <TextBlock Grid.Row="3"
                       Text="{Binding Greet}"
                       FontSize="18"
                       Foreground="#8A8A8A"
                       Margin="0,5,0,25" />

            <!-- WEATHER DETAILS -->
            <StackPanel Grid.Row="4">

                <!-- CONDITION -->
                <Border Background="#F8F8F8"
                        CornerRadius="15"
                        Padding="12"
                        Margin="0,0,0,10">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="☁"
                                   FontSize="18"
                                   Margin="0,0,10,0" />

                        <TextBlock Text="{Binding Condition}"
                                   FontSize="16"
                                   Foreground="#555" />

                    </StackPanel>

                </Border>

                <!-- RAIN -->
                <Border Background="#F8F8F8"
                        CornerRadius="15"
                        Padding="12"
                        Margin="0 0 0 10">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="🌧"
                                   FontSize="18"
                                   Margin="0,0,10,0" />

                        <TextBlock Text="{Binding Descrpt}"
                                   FontSize="16"
                                   Foreground="#555" />

                    </StackPanel>

                </Border>

                <Border Background="#F8F8F8"
                        CornerRadius="15"
                        Padding="12">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="🌧"
                                   FontSize="18"
                                   Margin="0,0,10,0" />

                        <TextBlock Text="{Binding DisplayCity}"
                                   FontSize="16"
                                   Foreground="#555" />

                    </StackPanel>

                </Border>

            </StackPanel>

