<UserControl x:Class="WeatherApp.View.ForecastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WeatherApp.View"
             xmlns:helpers="clr-namespace:WeatherApp.Helpers" 
             mc:Ignorable="d" 
             d:DesignHeight="700"
             d:DesignWidth="1000">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Border Background="White"
            CornerRadius="30"
            Padding="25">
        <Grid Margin="20,20,20,0">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="170" />
                <RowDefinition Height="Auto" /> 
            </Grid.RowDefinitions>

            <!-- TOP NAVIGATION -->
            <Grid Grid.Row="0"
                  Margin="0,0,0,25">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- TODAY / WEEK -->
                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Week"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111" />
                </StackPanel>

                <!-- TEMPERATURE TOGGLE -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <!-- Celsius -->
                    <Button Width="45"
                            Height="45"
                            Margin="0,0,10,0"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Content="°C"
                            Visibility="{Binding ButtonVisibility, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding CelciusCommand}">

                        <Button.Style>

                            <Style TargetType="Button">

                                <!-- DEFAULT -->
                                <Setter Property="Background"
                                        Value="White" />

                                <Setter Property="Foreground"
                                        Value="Black" />

                                <!-- HIGHLIGHT -->
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsCelsius}"
                                                 Value="True">

                                        <Setter Property="Background"
                                                Value="Black" />

                                        <Setter Property="Foreground"
                                                Value="White" />

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="22.5">

                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />

                                </Border>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                    <!-- Fahrenheit -->
                    <Button Width="45"
                            Height="45"
                            BorderThickness="0"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Content="°F"
                            Visibility="{Binding ButtonVisibility, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding FarenheitCommand}">

                        <Button.Style>

                            <Style TargetType="Button">

                                <!-- DEFAULT -->
                                <Setter Property="Background"
                                        Value="White" />

                                <Setter Property="Foreground"
                                        Value="Black" />

                                <!-- HIGHLIGHT -->
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsCelsius}"
                                                 Value="False">

                                        <Setter Property="Background"
                                                Value="Black" />

                                        <Setter Property="Foreground"
                                                Value="White" />

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">

                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="22.5">

                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />

                                </Border>

                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </StackPanel>
            </Grid>
 
            <local:WeeklyForecastView Grid.Row="1" />

            <!-- TODAY'S HIGHLIGHTS -->
            <Grid Grid.Row="2">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
 
                <TextBlock Text="Today's Highlights"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10" />
 
                <UniformGrid Grid.Row="1"
                             Columns="3"
                             Rows="2">
 
                    <Border 
                            CornerRadius="25"
                            Background="#F5F5F5"
                            Margin="0,0,20,20"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Humidity"
                                       Foreground="#999"
                                       FontSize="16" />

                            <TextBlock Text="{Binding Humidity}"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Margin="0,20,0,10" />

                            <TextBlock Text="{Binding HumidityStat}"
                                       FontSize="16" />

                        </StackPanel>

                    </Border>
 
                    <Border Background="#F5F5F5"
                            CornerRadius="25"
                            Margin="0,0,20,20"
                            Padding="20">

                        <StackPanel> 
                            <TextBlock Text="Wind Status"
                                       Foreground="#999"
                                       FontSize="16" />

                            <TextBlock Text="{Binding Wind}"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Margin="0,20,0,10" />

                            <TextBlock Text="{Binding WindStat}"
                                       FontSize="16" /> 
                        </StackPanel>

                    </Border> 
                    
                    <Border Background="#F5F5F5"
                            CornerRadius="25"
                            Margin="0,0,20,20"
                            Padding="20">

                        <StackPanel>

                            <TextBlock Text="Visibility"
                                       Foreground="#999"
                                       FontSize="16" />

                            <TextBlock Text="{Binding Visibility}"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Margin="0,20,0,10" />

                            <TextBlock Text="{Binding VisibilityStat}"
                                       FontSize="16" />

                        </StackPanel>

                    </Border>
 
                </UniformGrid>

            </Grid>
 
            
        </Grid>
        
    </Border>
   
</UserControl>